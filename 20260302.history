              "name": "fs_write",
              "orig_name": "fs_write",
              "args": {
                "command": "create",
                "file_text": "* { margin: 0; padding: 0; box-sizing: border-box; }\n\n:root {\n    --bg-dark: #0a0e17;\n    --bg-card: #131a2b;\n    --bg-surface: #1a2332;\n    --text-primary: #e8edf5;\n    --text-secondary: #8892a4;\n    --text-dim: #4a5568;\n    --accent-blue: #4a9eff;\n    --accent-green: #34d399;\n    --accent-red: #f87171;\n    --accent-amber: #fbbf24;\n    --accent-purple: #a78bfa;\n    --border: #1e2d42;\n}\n\nbody {\n    font-family: 'SF Pro Text', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n    background: var(--bg-dark);\n    color: var(--text-primary);\n    min-height: 100vh;\n    overflow-x: hidden;\n}\n\n/* === Screens === */\n.screen { display: none; min-height: 100vh; }\n.screen.active { display: flex; }\n\n/* === Start Screen === */\n#start-screen {\n    background: linear-gradient(180deg, #0a0e17 0%, #131a2b 50%, #0a0e17 100%);\n    align-items: center;\n    justify-content: center;\n}\n\n.start-overlay { text-align: center; max-width: 600px; padding: 40px; }\n\n.start-badge {\n    display: inline-block;\n    padding: 6px 16px;\n    background: rgba(74, 158, 255, 0.1);\n    border: 1px solid rgba(74, 158, 255, 0.3);\n    border-radius: 20px;\n    font-size: 12px;\n    color: var(--accent-blue);\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    margin-bottom: 24px;\n}\n\n.start-title {\n    font-size: 48px;\n    font-weight: 700;\n    color: var(--text-primary);\n    margin-bottom: 24px;\n    letter-spacing: 4px;\n}\n\n.start-desc {\n    font-size: 16px;\n    line-height: 1.8;\n    color: var(--text-secondary);\n    margin-bottom: 40px;\n}\n\n#player-name {\n    width: 100%;\n    max-width: 360px;\n    padding: 14px 20px;\n    background: var(--bg-surface);\n    border: 1px solid var(--border);\n    border-radius: 8px;\n    color: var(--text-primary);\n    font-size: 16px;\n    text-align: center;\n    margin-bottom: 20px;\n    transition: border-color 0.3s;\n}\n\n#player-name:focus { outline: none; border-color: var(--accent-blue); }\n#player-name::placeholder { color: var(--text-dim); }\n\n.btn-start {\n    display: inline-block;\n    padding: 16px 48px;\n    background: linear-gradient(135deg, var(--accent-blue), #2563eb);\n    color: white;\n    border: none;\n    border-radius: 8px;\n    font-size: 16px;\n    font-weight: 600;\n    cursor: pointer;\n    letter-spacing: 1px;\n    transition: all 0.3s;\n}\n\n.btn-start:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(74, 158, 255, 0.3); }\n\n.start-history-link {\n    display: block;\n    margin-top: 24px;\n    color: var(--text-dim);\n    text-decoration: none;\n    font-size: 14px;\n    transition: color 0.3s;\n}\n\n.start-history-link:hover { color: var(--text-secondary); }\n\n/* === Game Screen === */\n#game-screen { flex-direction: column; }\n\n.top-bar {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 16px 32px;\n    background: var(--bg-card);\n    border-bottom: 1px solid var(--border);\n    position: sticky;\n    top: 0;\n    z-index: 10;\n}\n\n.top-bar-left { display: flex; align-items: center; gap: 16px; }\n\n.round-badge {\n    padding: 4px 12px;\n    background: rgba(74, 158, 255, 0.15);\n    border: 1px solid rgba(74, 158, 255, 0.3);\n    border-radius: 4px;\n    font-size: 12px;\n    font-weight: 700;\n    color: var(--accent-blue);\n    letter-spacing: 1px;\n}\n\n.location-text { font-size: 13px; color: var(--text-dim); }\n\n.top-bar-right { display: flex; gap: 24px; }\n\n.meter { display: flex; align-items: center; gap: 8px; }\n.meter-label { font-size: 12px; color: var(--text-secondary); white-space: nowrap; }\n\n.meter-bar {\n    width: 120px;\n    height: 6px;\n    background: var(--bg-dark);\n    border-radius: 3px;\n    overflow: hidden;\n}\n\n.meter-fill {\n    height: 100%;\n    border-radius: 3px;\n    transition: width 0.8s ease, background 0.5s;\n}\n\n.meter-fill.safety { background: var(--accent-green); }\n.meter-fill.willingness { background: var(--accent-blue); }\n\n.meter-value { font-size: 14px; font-weight: 700; color: var(--text-primary); min-width: 24px; }\n\n/* === Game Body === */\n.game-body {\n    flex: 1;\n    max-width: 800px;\n    margin: 0 auto;\n    padding: 40px 32px;\n    width: 100%;\n}\n\n/* Narrative */\n.narrative-area { margin-bottom: 32px; }\n\n.scene-narration {\n    font-size: 15px;\n    line-height: 1.9;\n    color: var(--text-secondary);\n    font-style: italic;\n    padding: 20px 24px;\n    border-left: 2px solid var(--text-dim);\n    animation: fadeSlideIn 0.8s ease;\n}\n\n.scene-location {\n    font-size: 12px;\n    color: var(--text-dim);\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    margin-bottom: 12px;\n}\n\n/* Dialogue */\n.dialogue-area { margin-bottom: 40px; }\n\n.npc-block {\n    animation: fadeSlideIn 0.6s ease;\n}\n\n.npc-action {\n    font-size: 14px;\n    color: var(--accent-amber);\n    margin-bottom: 12px;\n    font-style: italic;\n}\n\n.npc-dialogue {\n    font-size: 18px;\n    line-height: 1.7;\n    color: var(--text-primary);\n    padding: 24px;\n    background: var(--bg-surface);\n    border-radius: 12px;\n    border: 1px solid var(--border);\n    position: relative;\n}\n\n.npc-name {\n    font-size: 12px;\n    color: var(--accent-red);\n    font-weight: 600;\n    letter-spacing: 1px;\n    margin-bottom: 8px;\n}\n\n/* Reaction overlay */\n.reaction-block {\n    padding: 20px 24px;\n    margin-bottom: 24px;\n    border-radius: 8px;\n    animation: fadeSlideIn 0.5s ease;\n}\n\n.reaction-action {\n    font-size: 14px;\n    color: var(--accent-amber);\n    font-style: italic;\n    margin-bottom: 8px;\n}\n\n.reaction-thought {\n    font-size: 14px;\n    color: var(--text-dim);\n    font-style: italic;\n}\n\n.reaction-thought::before { content: '💭 '; }\n\n/* Choices */\n.choices-area {\n    display: flex;\n    flex-direction: column;\n    gap: 12px;\n}\n\n.choice-btn {\n    padding: 18px 24px;\n    background: var(--bg-card);\n    border: 1px solid var(--border);\n    border-radius: 8px;\n    color: var(--text-primary);\n    font-size: 15px;\n    line-height: 1.6;\n    text-align: left;\n    cursor: pointer;\n    transition: all 0.3s;\n    animation: fadeSlideUp 0.5s ease backwards;\n}\n\n.choice-btn:nth-child(1) { animation-delay: 0.1s; }\n.choice-btn:nth-child(2) { animation-delay: 0.2s; }\n.choice-btn:nth-child(3) { animation-delay: 0.3s; }\n\n.choice-btn:hover {\n    border-color: var(--accent-blue);\n    background: rgba(74, 158, 255, 0.05);\n    transform: translateX(6px);\n}\n\n.choice-btn:disabled {\n    opacity: 0.3;\n    cursor: not-allowed;\n    transform: none;\n}\n\n.choice-btn.selected {\n    border-color: var(--accent-blue);\n    background: rgba(74, 158, 255, 0.1);\n}\n\n/* Player echo */\n.player-echo {\n    padding: 16px 24px;\n    background: rgba(74, 158, 255, 0.05);\n    border-left: 3px solid var(--accent-blue);\n    border-radius: 0 8px 8px 0;\n    margin-bottom: 24px;\n    animation: fadeSlideIn 0.5s ease;\n}\n\n.player-echo-label {\n    font-size: 12px;\n    color: var(--accent-blue);\n    font-weight: 600;\n    margin-bottom: 6px;\n}\n\n.player-echo-text {\n    font-size: 15px;\n    color: var(--text-primary);\n    line-height: 1.6;\n}\n\n/* === Transition overlay === */\n.transition-overlay {\n    position: fixed;\n    inset: 0;\n    background: var(--bg-dark);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    z-index: 100;\n    opacity: 0;\n    pointer-events: none;\n    transition: opacity 0.5s;\n}\n\n.transition-overlay.active { opacity: 1; pointer-events: all; }\n\n.transition-text {\n    font-size: 14px;\n    color: var(--text-dim);\n    letter-spacing: 3px;\n    text-transform: uppercase;\n}\n\n/* === Value change flash === */\n.meter-value.flash-up {\n    color: var(--accent-green);\n    animation: flashPulse 0.8s ease;\n}\n\n.meter-value.flash-down {\n    color: var(--accent-red);\n    animation: flashPulse 0.8s ease;\n}\n\n/* === End Screen === */\n#end-screen {\n    background: linear-gradient(180deg, #0a0e17 0%, #131a2b 100%);\n    align-items: center;\n    justify-content: center;\n}\n\n.end-overlay { max-width: 640px; padding: 40px; text-align: center; }\n\n.end-icon { font-size: 64px; margin-bottom: 16px; }\n\n.end-title {\n    font-size: 36px;\n    font-weight: 700;\n    margin-bottom: 12px;\n}\n\n.end-title.win { color: var(--accent-green); }\n.end-title.lose { color: var(--accent-red); }\n\n.end-reason {\n    font-size: 16px;\n    color: var(--text-secondary);\n    margin-bottom: 32px;\n    line-height: 1.6;\n}\n\n.end-stats {\n    display: flex;\n    justify-content: center;\n    gap: 32px;\n    margin-bottom: 32px;\n}\n\n.end-stat {\n    text-align: center;\n}\n\n.end-stat-value {\n    font-size: 28px;\n    font-weight: 700;\n    color: var(--text-primary);\n}\n\n.end-stat-label {\n    font-size: 12px;\n    color: var(--text-dim);\n    margin-top: 4px;\n}\n\n.aar-box {\n    background: var(--bg-surface);\n    border: 1px solid var(--border);\n    border-radius: 12px;\n    padding: 24px;\n    text-align: left;\n    margin-bottom: 32px;\n}\n\n.aar-title {\n    font-size: 12px;\n    color: var(--text-dim);\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    margin-bottom: 16px;\n}\n\n.aar-content {\n    font-size: 15px;\n    line-height: 1.8;\n    color: var(--text-secondary);\n    white-space: pre-line;\n}\n\n.end-actions { display: flex; gap: 16px; justify-content: center; align-items: center; }\n\n.btn-ghost {\n    padding: 16px 32px;\n    background: transparent;\n    border: 1px solid var(--border);\n    border-radius: 8px;\n    color: var(--text-secondary);\n    font-size: 14px;\n    text-decoration: none;\n    transition: all 0.3s;\n}\n\n.btn-ghost:hover { border-color: var(--text-secondary); color: var(--text-primary); }\n\n/* === History Page === */\n.history-page {\n    max-width: 800px;\n    margin: 0 auto;\n    padding: 40px 32px;\n}\n\n.history-page-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    margin-bottom: 32px;\n}\n\n.history-page-header h1 { font-size: 24px; color: var(--text-primary); }\n\n.history-item {\n    background: var(--bg-card);\n    border: 1px solid var(--border);\n    border-radius: 12px;\n    padding: 24px;\n    margin-bottom: 16px;\n}\n\n.history-header-row {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    margin-bottom: 12px;\n}\n\n.player-name { font-size: 16px; font-weight: 600; color: var(--text-primary); }\n\n.result-badge {\n    padding: 4px 12px;\n    border-radius: 4px;\n    font-size: 12px;\n    font-weight: 600;\n}\n\n.result-badge.win { background: rgba(52, 211, 153, 0.15); color: var(--accent-green); }\n.result-badge.lose { background: rgba(248, 113, 113, 0.15); color: var(--accent-red); }\n\n.history-stats {\n    display: flex;\n    gap: 20px;\n    font-size: 13px;\n    color: var(--text-secondary);\n    margin-bottom: 8px;\n}\n\n.history-time { font-size: 12px; color: var(--text-dim); margin-bottom: 16px; }\n\n.dialogue-details {\n    border: 1px solid var(--border);\n    border-radius: 8px;\n    margin-bottom: 16px;\n    overflow: hidden;\n}\n\n.dialogue-details summary {\n    padding: 12px 16px;\n    background: var(--bg-surface);\n    color: var(--text-secondary);\n    cursor: pointer;\n    font-size: 14px;\n    user-select: none;\n}\n\n.dialogue-details summary:hover { color: var(--text-primary); }\n\n.dialogue-content { padding: 16px; }\n\n.history-dialogue {\n    margin-bottom: 16px;\n    padding-bottom: 16px;\n    border-bottom: 1px solid var(--border);\n}\n\n.history-dialogue:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }\n\n.history-npc {\n    padding: 10px 12px;\n    background: rgba(248, 113, 113, 0.05);\n    border-left: 3px solid var(--accent-red);\n    border-radius: 0 6px 6px 0;\n    margin-bottom: 8px;\n    font-size: 14px;\n    line-height: 1.5;\n    color: var(--text-secondary);\n}\n\n.history-player {\n    padding: 10px 12px;\n    background: rgba(74, 158, 255, 0.05);\n    border-left: 3px solid var(--accent-blue);\n    border-radius: 0 6px 6px 0;\n    font-size: 14px;\n    line-height: 1.5;\n    color: var(--text-secondary);\n}\n\n.history-choice-type {\n    display: inline-block;\n    padding: 2px 8px;\n    border-radius: 3px;\n    font-size: 11px;\n    margin-left: 8px;\n}\n\n.history-choice-type.correct { background: rgba(52, 211, 153, 0.15); color: var(--accent-green); }\n.history-choice-type.trap { background: rgba(248, 113, 113, 0.15); color: var(--accent-red); }\n.history-choice-type.neutral { background: rgba(251, 191, 36, 0.15); color: var(--accent-amber); }\n\n.aar-section { margin-top: 16px; }\n\n.aar-preview {\n    background: var(--bg-surface);\n    padding: 16px;\n    border-radius: 8px;\n    font-size: 14px;\n    line-height: 1.7;\n    color: var(--text-secondary);\n    white-space: pre-line;\n}\n\n.empty-state {\n    text-align: center;\n    padding: 80px 20px;\n    color: var(--text-dim);\n    font-size: 16px;\n}\n\n/* === Animations === */\n@keyframes fadeSlideIn {\n    from { opacity: 0; transform: translateY(12px); }\n    to { opacity: 1; transform: translateY(0); }\n}\n\n@keyframes fadeSlideUp {\n    from { opacity: 0; transform: translateY(20px); }\n    to { opacity: 1; transform: translateY(0); }\n}\n\n@keyframes flashPulse {\n    0%, 100% { transform: scale(1); }\n    50% { transform: scale(1.3); }\n}\n\n@keyframes typewriter {\n    from { width: 0; }\n    to { width: 100%; }\n}\n\n/* === Responsive === */\n@media (max-width: 768px) {\n    .top-bar { flex-direction: column; gap: 12px; padding: 12px 16px; }\n    .top-bar-right { width: 100%; justify-content: space-between; }\n    .game-body { padding: 24px 16px; }\n    .start-title { font-size: 32px; }\n    .meter-bar { width: 80px; }\n}\n",
