              "args": {
                "command": "str_replace",
                "new_str": ".aar-preview {\n    background: #f9f9f9;\n    padding: 12px;\n    border-radius: 4px;\n    font-size: 14px;\n    line-height: 1.6;\n    white-space: pre-line;\n}\n\n.dialogue-details {\n    margin: 16px 0;\n    border: 1px solid #e0e0e0;\n    border-radius: 8px;\n    overflow: hidden;\n}\n\n.dialogue-details summary {\n    padding: 12px 16px;\n    background: #f5f5f5;\n    cursor: pointer;\n    font-weight: 600;\n    user-select: none;\n}\n\n.dialogue-details summary:hover {\n    background: #e8e8e8;\n}\n\n.dialogue-content {\n    padding: 16px;\n    max-height: 400px;\n    overflow-y: auto;\n}\n\n.history-dialogue {\n    margin-bottom: 16px;\n    padding-bottom: 16px;\n    border-bottom: 1px solid #f0f0f0;\n}\n\n.history-dialogue:last-child {\n    border-bottom: none;\n}\n\n.history-npc {\n    margin-bottom: 8px;\n    padding: 8px;\n    background: #fff3e0;\n    border-radius: 4px;\n    font-size: 14px;\n    line-height: 1.5;\n}\n\n.history-player {\n    padding: 8px;\n    background: #e3f2fd;\n    border-radius: 4px;\n    font-size: 14px;\n    line-height: 1.5;\n}\n\n.aar-section {\n    margin-top: 16px;\n}\n\n.aar-title {\n    font-weight: 600;\n    margin-bottom: 8px;\n    color: #666;\n}",
